# Next.js reads .env.local from this directory (not the repo root).
# Copy NEXT_PUBLIC_* vars from the repo-root .env.example:
#
#   cp ../../.env.example .env.local
#   # then keep only the NEXT_PUBLIC_* lines, or copy the whole file
#
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_SWARM_API_URL=http://localhost:8765
# NEXT_PUBLIC_SWARM_WS_URL=ws://localhost:8765/ws
