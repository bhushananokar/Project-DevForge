# ============================================================
# Copy this file to .env and fill in the values you need.
# Lines beginning with # are comments / optional variables.
#
# Single env file for:
#   - DevForge swarm (CLI, dashboard, agents)
#   - swarmcality-Frontend PromptForge API (backend)
#   - swarmcality-Frontend Next.js UI (copy NEXT_PUBLIC_* to frontend/.env.local)
# ============================================================

# ── LLM Providers (at least one required for agents) ─────────
# GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-v1-...

# PromptForge notebook API — prompt generation, transcription, image analysis
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── GitHub (required for repo search, clone, templates, CI) ──
# SWARM_GITHUB_TOKEN=ghp_...
# Boilerplate templates (https://github.com/BreakingEnigmaVIT — repos boilerplate-*)
# SWARM_TEMPLATE_ORG=BreakingEnigmaVIT

# ── Context7 / Repo Search ───────────────────────────────────
# Max GitHub search results returned by context7_search
# CONTEXT7_MAX_RESULTS=10

# ── Swarm Core ────────────────────────────────────────────────
SWARM_PROVIDER=openrouter                  # groq | openrouter | gemini
SWARM_DEFAULT_MODEL=deepseek/deepseek-v4-pro
# SWARM_LOG_LEVEL=INFO
# SWARM_TRACE_DIR=./traces
# SWARM_MEMORY_DIR=./memory_store
# SWARM_OUTPUT_DIR=./swarm_output       # Host folder mounted into swarm container (docker-compose.full.yml)
# SWARM_SAFETY_MODE=auto                # auto | interactive

# ── Message Bus ───────────────────────────────────────────────
# SWARM_BUS_TRANSPORT=in-process       # in-process | redis
# SWARM_REDIS_URL=redis://localhost:6379

# ── API Server (swarm dashboard) ──────────────────────────────
# SWARM_API_PORT=8765

# ── Task Queue / Workers (Redis Streams + KEDA) ───────────────
# SWARM_DEPLOYMENT_MODE=local
# SWARM_STREAM_PREFIX=swarm
# SWARM_ORCHESTRATOR_ID=orchestrator
# SWARM_WORKER_ROLE=coder
# SWARM_WORKER_CONCURRENCY=1
# SWARM_WORKER_HOSTNAME=swarm-worker-1
# SWARM_WORKER_STUB=0

# ── PromptForge API (swarmcality-Frontend/backend) ────────────
# MongoDB — local dev: mongodb://localhost:27017  |  Docker: mongodb://mongodb:27017
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=promptforge
# JWT secret — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
# Comma-separated allowed browser origins for the Next.js UI
CORS_ORIGINS=http://localhost:3000

# ── Next.js UI (swarmcality-Frontend/frontend) ──────────────
# Copy these into swarmcality-Frontend/frontend/.env.local for `npm run dev`
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SWARM_API_URL=http://localhost:8765
NEXT_PUBLIC_SWARM_WS_URL=ws://localhost:8765/ws

# ── Search ────────────────────────────────────────────────────
# SWARM_TAVILY_API_KEY=tvly-...        # Falls back to DuckDuckGo if unset

# ── Observability ─────────────────────────────────────────────
# SWARM_GRAFANA_URL=http://grafana:3000
# SWARM_GRAFANA_TOKEN=glsa_...
# SWARM_PROMETHEUS_URL=http://prometheus:9090
# SWARM_LOKI_URL=http://loki:3100

# ── Incident Management ───────────────────────────────────────
# SWARM_PAGERDUTY_TOKEN=...
# SWARM_UPTIME_KUMA_URL=http://kuma:3001
# SWARM_UPTIME_KUMA_API_KEY=uk1_...

# ── Infrastructure / Integrations ────────────────────────────
# SWARM_CLOUDFLARE_TOKEN=...
# SWARM_NOTION_TOKEN=secret_...
# SWARM_LINEAR_TOKEN=lin_api_...
# SWARM_INTERCOM_TOKEN=...

# ── Databases ─────────────────────────────────────────────────
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=abcdefghij

# ── Secrets Backends (env_manager tool) ───────────────────────
# SWARM_DOPPLER_TOKEN=dp.st....
# VAULT_TOKEN=hvs....
# AWS_DEFAULT_REGION=us-east-1

# ── OAuth Helper ──────────────────────────────────────────────
# OAUTH_CLIENT_ID=...
# OAUTH_CLIENT_SECRET=...
