# PromptForge backend reads from this directory's .env when running locally.
# All variables are documented in the repo-root .env.example — copy from there:
#
#   cp ../../.env.example .env
#
# Required keys for this service:
#   OPENAI_API_KEY
#   MONGODB_URL
#   DATABASE_NAME
#   SECRET_KEY
#   CORS_ORIGINS
